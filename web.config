<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>

    <!-- Delegar el manejo de la app a iisnode -->
    <handlers>
      <add name="iisnode" path="server.js" verb="*" modules="iisnode" />
    </handlers>

    <rewrite>
      <rules>
        <!-- Servir archivos estáticos directamente (public/) -->
        <rule name="StaticContent" stopProcessing="true">
          <match url="^public/(.+)" />
          <action type="Rewrite" url="public/{R:1}" />
        </rule>

        <!-- Socket.io necesita su propia regla -->
        <rule name="SocketIO" stopProcessing="true">
          <match url="socket.io(.+)" />
          <action type="Rewrite" url="server.js" />
        </rule>

        <!-- Todo lo demás va a Node -->
        <rule name="NodeApp" stopProcessing="true">
          <match url=".*" />
          <conditions>
            <add input="{REQUEST_FILENAME}" matchType="IsFile" negate="true" />
          </conditions>
          <action type="Rewrite" url="server.js" />
        </rule>
      </rules>
    </rewrite>

    <!-- Configuración de iisnode -->
    <iisnode
      nodeProcessCommandLine="node.exe"
      watchedFiles="*.js"
      loggingEnabled="true"
      logDirectory="iisnode"
      debuggingEnabled="false"
    />

    <!-- Deshabilitar directoryBrowse -->
    <directoryBrowse enabled="false" />

  </system.webServer>
</configuration>
